---
layout: base
style_src: posts
---
<main>
  <article>
    <header>
      <nav class="back-to-collection">
        <small>
          <a href="/{{ page.collection }}">
            <i class="fa-solid fa-arrow-left" aria-hidden="true" role="presentation"></i>
            {{page.collection |  capitalize}}
          </a>
        </small>
      </nav>
      <h1>{{page.title}}</h1>
      <dl class="metadata">
        <dt class="sr-only">Published:</dt>
        <dd>{{ page.date | date: "%B %d, %Y" }}</dd>
        <dt class="sr-only">Estimated reading time</dt>
        <dd>{%- include reading-time.liquid -%} minute read</dd>
      </dl>
    </header>
    <div id="main-content" class="prose">
      {{ content }}
    </div>
  </article>
</main>
<script src="/assets/scripts/prism.js"></script>
